  "info": {
    "title": "Se7enSquare Backend API",
    "description": "In-memory NestJS backend for frontend integration and academic evaluation",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "x-role": {
        "type": "apiKey",
        "in": "header",
        "name": "x-role",
        "description": "RBAC role header: admin | moderator | user"
      }
    },
    "schemas": {
      "UserDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number",
            "example": 1
          },
          "username": {
            "type": "string",
            "example": "player01"
          },
          "email": {
            "type": "string",
            "example": "player@example.com"
          },
          "role": {
            "type": "string",
            "enum": [
              "admin",
              "moderator",
              "user"
            ],
            "example": "user"
          },
          "bio": {
            "type": "string",
            "example": "Casual and competitive gamer"
          }
        },
        "required": [
          "id",
          "username",
          "email",
          "role"
        ]
      },
      "CreateUserDto": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "minLength": 3,
            "maxLength": 30,
            "example": "newplayer"
          },
          "email": {
            "type": "string",
            "example": "newplayer@example.com"
          },
          "role": {
            "type": "string",
            "enum": [
              "admin",
              "moderator",
              "user"
            ],
            "example": "user"
          },
          "bio": {
            "type": "string",
            "minLength": 5,
            "maxLength": 160,
            "example": "Loves MMORPG and FPS."
          }
        },
        "required": [
          "username",
          "email",
          "role"
        ]
      },
      "UpdateUserDto": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string",
            "minLength": 3,
            "maxLength": 30,
            "example": "newplayer"
          },
          "email": {
            "type": "string",
            "example": "newplayer@example.com"
          },
          "role": {
            "type": "string",
            "enum": [
              "admin",
              "moderator",
              "user"
            ],
            "example": "user"
          },
          "bio": {
            "type": "string",
            "minLength": 5,
            "maxLength": 160,
            "example": "Loves MMORPG and FPS."
          }
        }
      },
      "CommunityDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number",
            "example": 1
          },
          "name": {
            "type": "string",
            "example": "FPS Arena"
          },
          "description": {
            "type": "string",
            "example": "Competitive FPS players and tournaments"
          },
          "ownerId": {
            "type": "number",
            "example": 3
          },
          "tags": {
            "example": [
              "fps",
              "esports"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "id",
          "name",
          "description",
          "ownerId",
          "tags"
        ]
